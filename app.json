{
  "expo": {
    "name": "ushuru-app",
    "slug": "ushuru-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ushurulogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alfredokwiri.ushuruapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "permissions": [
        "INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/ushuru.jpg",
        "backgroundColor": "#800000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.alfredokwiri.ushuruapp"
    },
    "web": {
      "favicon": "./assets/ushurulogo.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9136026a-7896-43e6-8bbf-90f87e6b388c"
      }
    }
  }
}